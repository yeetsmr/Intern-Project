{
  "openapi": "3.1.1",
  "info": {
    "title": "BackendAPI | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://localhost:7271"
    },
    {
      "url": "http://localhost:5083"
    }
  ],
  "paths": {
    "/api/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/tasks/filter-dynamic": {
      "post": {
        "tags": [
          "Task"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DataSourceRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/DataSourceRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/DataSourceRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/tasks/create": {
      "post": {
        "tags": [
          "Task"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Tasks"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/Tasks"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/Tasks"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Category": {
        "type": "integer"
      },
      "CompositeFilterDescriptor": {
        "type": "object",
        "properties": {
          "filterDescriptors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FilterDescriptor"
            }
          },
          "operator": {
            "$ref": "#/components/schemas/FilterCompositionLogicalOperator"
          }
        }
      },
      "DataSourceRequest": {
        "type": "object",
        "properties": {
          "pageNumber": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "pageSize": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "filter": {
            "$ref": "#/components/schemas/CompositeFilterDescriptor"
          },
          "sorts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SortDescriptor"
            }
          }
        }
      },
      "FilterCompositionLogicalOperator": {
        "type": "integer"
      },
      "FilterDescriptor": {
        "type": "object",
        "properties": {
          "member": {
            "type": "string"
          },
          "value": { },
          "operator": {
            "$ref": "#/components/schemas/FilterOperator"
          }
        }
      },
      "FilterOperator": {
        "type": "integer"
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "Priority": {
        "type": "integer"
      },
      "SortDescriptor": {
        "type": "object",
        "properties": {
          "member": {
            "type": "string"
          },
          "sortDirection": {
            "type": "string"
          }
        }
      },
      "Tasks": {
        "type": "object",
        "properties": {
          "id": {
            "type": [
              "null",
              "string"
            ]
          },
          "taskName": {
            "type": "string"
          },
          "assigneeName": {
            "type": "string"
          },
          "maxTime": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "estimatedCost": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "isCompleted": {
            "type": "boolean"
          },
          "isActive": {
            "type": "boolean"
          },
          "pri": {
            "$ref": "#/components/schemas/Priority"
          },
          "category": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Category"
              }
            ]
          },
          "createdAfter": {
            "type": "string",
            "format": "date-time"
          },
          "dueDate": {
            "type": "string",
            "format": "date-time"
          },
          "storyPoints": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "sprintNumber": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Auth"
    },
    {
      "name": "Task"
    }
  ]
}