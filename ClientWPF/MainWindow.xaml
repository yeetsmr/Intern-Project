<Window x:Class="ClientWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Intern-Project WPF Task Management" Height="500" Width="800">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Task Management System" FontSize="22" FontWeight="Bold" Foreground="#2C3E50"/>
            <TextBlock Text="API-Enabled Dynamic Filtering Panel" FontSize="12" Foreground="#7F8C8D"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Task Name:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,5,0" />
            <TextBox x:Name="txtTaskName" Width="80" Margin="0,0,15,0" Padding="2" />

            <TextBlock Text="Max Time:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,5,0" />
            <TextBox x:Name="txtMaxTime" Width="80" Margin="0,0,15,0" Padding="2" />

            <TextBlock Text="Priority:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,5,0" />
            <TextBox x:Name="txtPriority" Width="80" Margin="0,0,15,0" Padding="2" />

            <Button x:Name="btnFilter" Content="Filter" Width="100" Padding="5" Background="#111111" Foreground="GhostWhite" FontWeight="Bold" Click="btnFilter_Click"/>
            <Button x:Name="BtnLogin" Content="Login" Click="BtnLogin_Click" Foreground="Yellow" Background="Black" Width="100" Padding="5" Margin="5,0,0,0"/>
        </StackPanel>

        <ListView Grid.Row="2" Name="TaskListView" Background="#FAFAFA" BorderBrush="#BDC3C7" BorderThickness="1">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Task ID" DisplayMemberBinding="{Binding Id}" Width="150"/>
                    <GridViewColumn Header="Task Name" DisplayMemberBinding="{Binding TaskName}" Width="250"/>
                    <GridViewColumn Header="Max Time" DisplayMemberBinding="{Binding MaxTime}" Width="130"/>
                    <GridViewColumn Header="Priority" DisplayMemberBinding="{Binding PriorityText}" Width="100"/>
                    <GridViewColumn Header="Status" DisplayMemberBinding="{Binding IsCompleted}" Width="100"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button x:Name="btnPrevPage" Content="&lt; Previous Page" Width="100" Padding="5" Margin="0,0,15,0" Click="btnPrevPage_Click" Background="#BDC3C7" IsEnabled="False"/>
            <TextBlock x:Name="txtPageInfo" Text="Page: 1" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
            <Button x:Name="btnNextPage" Content="Next Page &gt;" Width="100" Padding="5" Margin="15,0,0,0" Click="btnNextPage_Click" Background="#2980B9" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>