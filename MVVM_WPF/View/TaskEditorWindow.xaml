<Window x:Class="MVVM_WPF.View.TaskEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Editor" Height="600" Width="400" WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20">
        <TextBlock Text="Task Details" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

        <TextBlock Text="Task Name"/>
        <TextBox Text="{Binding TaskName}" Margin="0,0,0,10"/>

        <TextBlock Text="Employee Name"/>
        <TextBox Text="{Binding EmployeeName}" Margin="0,0,0,10"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,25,10">
            <TextBlock Text="Due Date:" FontWeight="Bold" Foreground="#34495E" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <DatePicker x:Name="dpDueDate" SelectedDate="{Binding DueDate}" Width="110"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,0,25,10">
            <TextBlock Text="Created:" FontWeight="Bold" Foreground="#34495E" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <DatePicker x:Name="dpCreatedAfter" SelectedDate="{Binding CreatedAfter}" Width="110"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <StackPanel Width="180">
                <TextBlock Text="Priority"/>
                <ComboBox SelectedIndex="{Binding Priority}">
                    <ComboBoxItem Content="Low"/>
                    <ComboBoxItem Content="Mid"/>
                    <ComboBoxItem Content="High"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Width="180" Margin="10,0,0,0">
                <TextBlock Text="Category"/>
                <ComboBox SelectedIndex="{Binding Category}">
                    <ComboBoxItem Content="Work"/>
                    <ComboBoxItem Content="Personal"/>
                    <ComboBoxItem Content="Shopping"/>
                    <ComboBoxItem Content="Health"/>
                    <ComboBoxItem Content="Finance"/>
                    <ComboBoxItem Content="Education"/>
                    <ComboBoxItem Content="Entertainment"/>
                    <ComboBoxItem Content="Other"/>
                </ComboBox>
            </StackPanel>
        </StackPanel>

        <TextBlock Text="Max Time" Margin="0,10,0,0"/>
        <TextBox Text="{Binding MaxTime}"/>
        <TextBlock Text="Cost" Margin="0,10,0,0"/>
        <TextBox Text="{Binding EstimatedCost}"/>

        <TextBlock Text="Story Points"/>
        <TextBox Text="{Binding StoryPoints}"/>
        <TextBlock Text="Sprint"/>
        <TextBox Text="{Binding SprintNumber}"/>

        <CheckBox IsChecked="{Binding IsCompleted}" Content="Is Completed" Margin="0,10"/>
        <CheckBox IsChecked ="{Binding IsActive}" Content=" Status Active" Margin="0,10"/>

        <Button Content="Save" Click="Save_Click" Background="#27AE60" Foreground="White" Height="30"/>
    </StackPanel>
</Window>