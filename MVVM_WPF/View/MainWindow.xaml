<Window x:Class="MVVM_WPF.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:MVVM_WPF.Converters" 
        Title="Intern-Project WPF Task Management" Height="750" Width="1250"
        WindowStartupLocation="CenterScreen" Background="#F0F4F8">

    <Window.Resources>
        <conv:BrushConverter x:Key="BrushConverter"/>
        
        <Style x:Key="TaskRowStyle" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Margin" Value="0,2"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                    <Setter Property="Background" Value="#E8F8F5"/>
                    <Setter Property="Foreground" Value="#117A65"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="StatusIndicatorTemplate">
            <Border x:Name="Indicator" Width="8" Height="22" Background="Transparent" CornerRadius="4" HorizontalAlignment="Left"/>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsNew}" Value="True">
                    <Setter TargetName="Indicator" Property="Background" Value="#000080"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsUpdated}" Value="True">
                    <Setter TargetName="Indicator" Property="Background" Value="#FFD700"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid x:Name="MainAppContainer" Visibility="{Binding MainAppVisibility}" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Task Management System" FontSize="26" FontWeight="Bold" Foreground="#2C3E50"/>
                    <TextBlock Text="API-Enabled Dynamic Filtering Panel" FontSize="14" Foreground="#7F8C8D" Margin="0,4,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" Content="Logout" Command="{Binding LogoutCommand}" 
                        Background="#E74C3C" Foreground="White" FontWeight="Bold" Width="90" Height="35" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>

            <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" 
                    BorderBrush="#E1E8ED" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#DDDDDD" Direction="270" ShadowDepth="2" BlurRadius="5" Opacity="0.5"/>
                </Border.Effect>
                <StackPanel>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Task Name:" FontWeight="Bold" Foreground="#34495E" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <ComboBox x:Name="cmbNameOperator" Width="90" SelectedIndex="{Binding NameOperatorIndex}" Height="25">
                                <ComboBoxItem Content="Contains" />
                                <ComboBoxItem Content="Starts With" />
                                <ComboBoxItem Content="Ends With" />
                            </ComboBox>
                            <TextBox x:Name="txtTaskName" Width="140" Margin="10,0,20,0" Padding="4,2" Text="{Binding TaskNameFilter, UpdateSourceTrigger=PropertyChanged,TargetNullValue='', Delay=500}" VerticalContentAlignment="Center"/>

                            <TextBlock Text="Employee:" FontWeight="Bold" Foreground="#34495E" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBox x:Name="txtEmployeeName" Width="140" Padding="4,2" Text="{Binding EmployeeNameFilter, UpdateSourceTrigger=PropertyChanged,TargetNullValue='', Delay=500}" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <Button Grid.Column="2" x:Name="btnFilter" Content="Apply Filters" Command="{Binding FilterCommand}" 
                                Width="120" Height="30" Background="#34495E" Foreground="White" FontWeight="Bold" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>

                    <Separator Background="#ECF0F1" Margin="0,0,0,15"/>

                    <WrapPanel Orientation="Horizontal">
                        <StackPanel Orientation="Horizontal" Margin="0,0,25,10">
                            <TextBlock Text="Time:" FontWeight="Bold" Foreground="#34495E" Width="45" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtMinTime" Text="{Binding MinTimeFilter, UpdateSourceTrigger=PropertyChanged,TargetNullValue='', Delay=500}" Width="50" Padding="2" ToolTip="Min Time"/>
                            <TextBlock Text=" - " Margin="5,0" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtMaxTime" Text="{Binding MaxTimeFilter, UpdateSourceTrigger=PropertyChanged,TargetNullValue='', Delay=500}" Width="50" Padding="2" ToolTip="Max Time"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,25,10">
                            <TextBlock Text="Created:" FontWeight="Bold" Foreground="#34495E" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <DatePicker x:Name="dpStartDate" SelectedDate="{Binding StartDateFilter,TargetNullValue=''}" Width="110"/>
                            <TextBlock Text=" - " VerticalAlignment="Center" Margin="5,0"/>
                            <DatePicker x:Name="dpEndDate" SelectedDate="{Binding EndDateFilter}" Width="110"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,25,10">
                            <TextBlock Text="Due Date:" FontWeight="Bold" Foreground="#34495E" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <DatePicker x:Name="dpDueDate" SelectedDate="{Binding DueDateFilter,TargetNullValue=''}" Width="110"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,25,10">
                            <TextBlock Text="Priority:" FontWeight="Bold" Foreground="#34495E" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ComboBox x:Name="cmbPriority" SelectedIndex="{Binding SelectedPriorityIndex}" Width="90">
                                <ComboBoxItem Content="All" />
                                <ComboBoxItem Content="Low" />
                                <ComboBoxItem Content="Mid" />
                                <ComboBoxItem Content="High" />
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,25,10">
                            <TextBlock Text="Category:" FontWeight="Bold" Foreground="#34495E" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ComboBox x:Name="cmbCategory" SelectedIndex="{Binding SelectedCategoryIndex}" Width="110">
                                <ComboBoxItem Content="All" />
                                <ComboBoxItem Content="Work" />
                                <ComboBoxItem Content="Personal" />
                                <ComboBoxItem Content="Shopping" />
                                <ComboBoxItem Content="Health" />
                                <ComboBoxItem Content="Finance" />
                                <ComboBoxItem Content="Education" />
                                <ComboBoxItem Content="Travel" />
                                <ComboBoxItem Content="Entertainment" />
                                <ComboBoxItem Content="Other" />
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,25,10">
                            <TextBlock Text="Max Cost:" FontWeight="Bold" Foreground="#34495E" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="txtEstimatedCost" Text="{Binding EstimatedCostFilter, UpdateSourceTrigger=PropertyChanged,TargetNullValue='', Delay=500}" Width="60" Padding="2"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,25,10">
                            <TextBlock Text="Story Pts:" FontWeight="Bold" Foreground="#34495E" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="txtStoryPoints" Text="{Binding StoryPointsFilter, UpdateSourceTrigger=PropertyChanged,TargetNullValue='', Delay=500}" Width="50" Padding="2"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,25,10">
                            <TextBlock Text="Sprint:" FontWeight="Bold" Foreground="#34495E" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="txtSprintNumber" Text="{Binding SprintNumberFilter, UpdateSourceTrigger=PropertyChanged,TargetNullValue='', Delay=500}" Width="50" Padding="2"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,15,10">
                            <CheckBox x:Name="chkIsCompleted" IsChecked="{Binding IsCompletedFilter}" Content="Completed Only" VerticalAlignment="Center" FontWeight="Bold" Foreground="#27AE60"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <CheckBox x:Name="chkIsActive" IsChecked="{Binding IsActiveFilter}" Content="Active Only" VerticalAlignment="Center" FontWeight="Bold" Foreground="#2980B9"/>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="10,15" Margin="0,0,0,15"
                    BorderBrush="#E1E8ED" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#DDDDDD" Direction="270" ShadowDepth="1" BlurRadius="4" Opacity="0.4"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="+ Create New Task" Command="{Binding AddTaskCommand}" 
                            Width="160" Height="35" Background="#27AE60" Foreground="White" FontWeight="Bold" Cursor="Hand" FontSize="13">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Selected Action:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="#7F8C8D"/>

                        <Button Content="Edit Task" Command="{Binding UpdateTaskCommand}" 
                                Width="100" Height="35" Background="#F39C12" Foreground="White" FontWeight="Bold" Margin="0,0,10,0" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Content="Delete" Command="{Binding DeleteTaskCommand}" 
                                Width="100" Height="35" Background="#C0392B" Foreground="White" FontWeight="Bold" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="5" 
                    BorderBrush="#E1E8ED" BorderThickness="1" Margin="0,0,0,15">
                <Border.Effect>
                    <DropShadowEffect Color="#DDDDDD" Direction="270" ShadowDepth="2" BlurRadius="5" Opacity="0.5"/>
                </Border.Effect>

                <ListView Name="TaskListView" BorderThickness="0" ItemsSource="{Binding TaskList}" 
                          SelectedItem="{Binding UpdateTask, Mode=TwoWay}" 
                          ItemContainerStyle="{StaticResource TaskRowStyle}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn CellTemplate="{StaticResource StatusIndicatorTemplate}" Width="25"/>

                            <GridViewColumn Header="Task ID" DisplayMemberBinding="{Binding Id}" Width="150"/>
                            <GridViewColumn Header="Task Name" DisplayMemberBinding="{Binding TaskName}" Width="180"/>
                            <GridViewColumn Header="Employee" DisplayMemberBinding="{Binding EmployeeName}" Width="120"/>
                            <GridViewColumn Header="Category" DisplayMemberBinding="{Binding CategoryText}" Width="70"/>
                            <GridViewColumn Header="Cost" DisplayMemberBinding="{Binding EstimatedCost}" Width="70"/>
                            <GridViewColumn Header="SP" DisplayMemberBinding="{Binding StoryPoints}" Width="40"/>
                            <GridViewColumn Header="Sprint" DisplayMemberBinding="{Binding SprintNumber}" Width="50"/>
                            <GridViewColumn Header="Max Time" DisplayMemberBinding="{Binding MaxTime}" Width="70"/>
                            <GridViewColumn Header="Priority" DisplayMemberBinding="{Binding PriorityText}" Width="60"/>
                            <GridViewColumn Header="Active" DisplayMemberBinding="{Binding IsActive}" Width="50"/>
                            <GridViewColumn Header="Status" DisplayMemberBinding="{Binding IsCompleted}" Width="50"/>
                            <GridViewColumn Header="Created At" DisplayMemberBinding="{Binding CreatedAfter, StringFormat=\{0:dd.MM.yyyy\}}" Width="100"/>
                            <GridViewColumn Header="Due Date" DisplayMemberBinding="{Binding DueDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="100"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnPrevPage" Content="&lt; Previous" Command="{Binding PrevPageCommand}" Width="110" Height="30" Background="#BDC3C7" FontWeight="Bold" Cursor="Hand"/>
                <Border Background="White" CornerRadius="15" Padding="15,0" Margin="15,0">
                    <TextBlock x:Name="txtPageInfo" Text="{Binding CurrentPage, StringFormat='Page: \{0\}'}" VerticalAlignment="Center" FontWeight="Bold" FontSize="14" Foreground="#2C3E50"/>
                </Border>
                <Button x:Name="btnNextPage" Content="Next &gt;" Command="{Binding NextPageCommand}" Width="110" Height="30" Background="#2980B9" Foreground="White" FontWeight="Bold" Cursor="Hand"/>
            </StackPanel>
        </Grid>

        <Border x:Name="LoginOverlay" Visibility="{Binding LoginVisibility}" Background="#CC000000" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="White" CornerRadius="10" Width="380" Height="300" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="30">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="15" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="LOGIN SCREEN" FontSize="24" FontWeight="Bold" Margin="0,0,0,5" Foreground="#2C3E50" HorizontalAlignment="Center"/>

                    <TextBlock Text="Username" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtUsername" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="8,6" Margin="0,0,0,15" Background="#F8F9FA"/>

                    <TextBlock Text="Password" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="txtPassword" Height="35" Padding="8,6" Margin="0,0,0,25" Background="#F8F9FA"/>

                    <Button x:Name="BtnLoginSubmit" Content="LOGIN" Command="{Binding LoginCommand}" CommandParameter="{Binding ElementName=txtPassword}" 
                            Height="40" Background="#2980B9" Foreground="White" FontWeight="Bold" FontSize="14" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>